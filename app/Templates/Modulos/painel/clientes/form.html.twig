{% extends 'Layouts/painel' %}
{% block page_title %}{{ cliente ? 'Editar Cliente' : 'Novo Cliente' }}{% endblock %}
{% block page_heading %}{{ cliente ? 'Editar Cliente' : 'Novo Cliente' }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.clientes') }}">Clientes</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ cliente ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ cliente ? 'Editar Cliente' : 'Novo Cliente' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.clientes.salvar') }}">
            {% if cliente %}
            <input type="hidden" name="ID_CLIENTE" value="{{ cliente.ID_CLIENTE }}">
            {% endif %}

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="NOME">Nome</label>
                    <input type="text" id="NOME" name="NOME" class="form-control" value="{{ old('NOME', cliente.NOME ?? '') }}" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="NOME_FANTASIA">Nome Fantasia</label>
                    <input type="text" id="NOME_FANTASIA" name="NOME_FANTASIA" class="form-control" value="{{ old('NOME_FANTASIA', cliente.NOME_FANTASIA ?? '') }}">
                </div>

                <div class="form-group">
                    <label class="form-label" for="TIPO_ID">Tipo</label>
                    <select id="TIPO_ID" name="TIPO_ID" class="form-control">
                        <option value="0">— Selecione —</option>
                        <option value="1" {{ (old('TIPO_ID', cliente.TIPO_ID ?? '') == '1') ? 'selected' : '' }}>Pessoa Física</option>
                        <option value="2" {{ (old('TIPO_ID', cliente.TIPO_ID ?? '') == '2') ? 'selected' : '' }}>Pessoa Jurídica</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="SITUACAO_ID">Situação</label>
                    <select id="SITUACAO_ID" name="SITUACAO_ID" class="form-control" required>
                        <option value="">— Selecione —</option>
                        {% for s in situacoes %}
                        <option value="{{ s.ID_SITUACAO }}" {{ (old('SITUACAO_ID', cliente.SITUACAO_ID ?? '') == s.ID_SITUACAO) ? 'selected' : '' }}>
                            {{ s.DESCRICAO }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ route_to('painel.clientes') }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    {{ cliente ? 'Atualizar' : 'Salvar' }}
                </button>
            </div>
        </form>
    </div>
</div>

{% endblock %}
