{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}
{% import 'Componentes/selectTipo' as tipo %}

{% block page_title %}{{ endereco ? 'Editar Endereço' : 'Novo Endereço' }}{% endblock %}
{% block page_heading %}{{ endereco ? 'Editar Endereço' : 'Novo Endereço' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.clientes') }}">Clientes</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.clientes.editar', cliente.uuid) }}">{{ cliente.nome }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ endereco ? 'Editar Endereço' : 'Novo Endereço' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>Dados do Endereço</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.clientes.endereco.salvar', cliente.uuid) }}">
            {{ csrf_field()|raw }}
            {% if endereco %}
                {{ forms.input('ID_ENDERECO', '', endereco.ID_ENDERECO, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ tipo.select('TIPO_ID', old('TIPO_ID', endereco.TIPO_ID ?? ''), 'TIPO_ENDERECO', '', { label: 'Tipo de Endereço', required: true, col: 'col-4 col-md-12' }) }}

                {{ forms.select('PRINCIPAL', 'Endereço Principal?', old('PRINCIPAL', endereco.PRINCIPAL ?? '0'), [
                    {value: '0', label: 'Não'},
                    {value: '1', label: 'Sim'}
                ], {
                    required: true,
                    col: 'col-4 col-md-12',
                    value_key: 'value',
                    text_key: 'label',
                    disabled: (endereco is not null)
                }) }}

                {{ forms.input('CEP', 'CEP', old('CEP', endereco.CEP ?? ''), 'text', {
                    required: true,
                    col: 'col-4 col-md-12',
                    placeholder: '00000-000',
                    mask: 'cep'
                }) }}

                {{ forms.input('LOGRADOURO', 'Logradouro', old('LOGRADOURO', endereco.LOGRADOURO ?? ''), 'text', {
                    required: true,
                    col: 'col-8 col-md-12',
                    placeholder: 'Rua, Avenida, etc.'
                }) }}

                {{ forms.input('NUMERO', 'Número', old('NUMERO', endereco.NUMERO ?? ''), 'text', {
                    required: true,
                    col: 'col-4 col-md-12',
                    placeholder: 'Ex: 123'
                }) }}

                {{ forms.input('COMPLEMENTO', 'Complemento', old('COMPLEMENTO', endereco.COMPLEMENTO ?? ''), 'text', {
                    col: 'col-4 col-md-12',
                    placeholder: 'Apto, Sala, Bloco, etc.'
                }) }}

                {{ forms.input('BAIRRO', 'Bairro', old('BAIRRO', endereco.BAIRRO ?? ''), 'text', {
                    required: true,
                    col: 'col-4 col-md-12',
                    placeholder: 'Bairro'
                }) }}

                {{ forms.input('CIDADE', 'Cidade', old('CIDADE', endereco.CIDADE ?? ''), 'text', {
                    required: true,
                    col: 'col-2 col-md-12',
                    placeholder: 'Cidade'
                }) }}

                {{ forms.select('UF', 'UF', old('UF', endereco.UF ?? ''), [
                    'AC', 'AL', 'AP', 'AM', 'BA', 'CE', 'DF', 'ES', 'GO',
                    'MA', 'MT', 'MS', 'MG', 'PA', 'PB', 'PR', 'PE', 'PI',
                    'RJ', 'RN', 'RS', 'RO', 'RR', 'SC', 'SP', 'SE', 'TO'
                ], {
                    required: true,
                    col: 'col-2 col-md-12'
                }) }}

                {{ forms.actions(route_to('painel.clientes.editar', cliente.uuid), endereco ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const cepInput = document.getElementById('CEP');
    if (cepInput) {
        cepInput.addEventListener('blur', function() {
            const cep = this.value.replace(/\D/g, '');
            if (cep.length === 8) {
                // Efeito visual premium de loading nos campos
                const fields = ['LOGRADOURO', 'BAIRRO', 'CIDADE', 'UF'];
                fields.forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.placeholder = 'Carregando...';
                });

                fetch(`https://viacep.com.br/ws/${cep}/json/`)
                    .then(response => response.json())
                    .then(data => {
                        if (!data.erro) {
                            if (document.getElementById('LOGRADOURO')) document.getElementById('LOGRADOURO').value = data.logradouro;
                            if (document.getElementById('BAIRRO')) document.getElementById('BAIRRO').value = data.bairro;
                            if (document.getElementById('CIDADE')) document.getElementById('CIDADE').value = data.localidade;
                            if (document.getElementById('UF')) document.getElementById('UF').value = data.uf;
                        } else {
                            alert('CEP não encontrado.');
                        }
                    })
                    .catch(err => console.error('Erro ao buscar CEP:', err))
                    .finally(() => {
                        fields.forEach(id => {
                            const el = document.getElementById(id);
                            if (el) el.placeholder = '';
                        });
                    });
            }
        });
    }
});
</script>

{% endblock %}
