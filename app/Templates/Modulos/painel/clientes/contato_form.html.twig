{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}

{% block page_title %}{{ contato ? 'Editar Contato' : 'Novo Contato' }}{% endblock %}
{% block page_heading %}{{ contato ? 'Editar Contato' : 'Novo Contato' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.clientes') }}">Clientes</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.clientes.editar', cliente.UUID) }}">{{ cliente.nome }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ contato ? 'Editar Contato' : 'Novo Contato' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ contato ? 'Editar Contato' : 'Novo Contato' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.clientes.contato.salvar', cliente.UUID) }}">
            {{ csrf_field()|raw }}
            {% if contato %}
                {{ forms.input('ID_CONTATO', '', contato.ID_CONTATO, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ forms.input('NOME', 'Nome do Contato', old('NOME', contato.NOME ?? ''), 'text', {
                    required: true,
                    col: 'col-6 col-md-12',
                    placeholder: 'Nome completo'
                }) }}

                {{ forms.input('CARGO', 'Cargo', old('CARGO', contato.CARGO ?? ''), 'text', {
                    col: 'col-6 col-md-12',
                    placeholder: 'Cargo/função'
                }) }}

                {{ forms.input('TELEFONE', 'Telefone', old('TELEFONE', contato.TELEFONE ?? ''), 'text', {
                    col: 'col-4 col-md-12',
                    placeholder: '(00) 0000-0000',
                    mask: 'phone'
                }) }}

                {{ forms.input('EMAIL', 'E-mail', old('EMAIL', contato.EMAIL ?? ''), 'email', {
                    col: 'col-4 col-md-12',
                    placeholder: 'email@exemplo.com'
                }) }}

                {{ forms.input('WHATSAPP', 'WhatsApp', old('WHATSAPP', contato.WHATSAPP ?? ''), 'text', {
                    col: 'col-4 col-md-12',
                    placeholder: '(00) 00000-0000',
                    mask: 'phone'
                }) }}

                {{ forms.actions(route_to('painel.clientes.editar', cliente.UUID), contato ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

{% endblock %}
