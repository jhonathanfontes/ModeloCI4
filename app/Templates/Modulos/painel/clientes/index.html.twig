{% extends 'Layouts/painel' %}
{% block page_title %}Clientes{% endblock %}
{% block page_heading %}Clientes{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Clientes</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('painel.clientes.novo') }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Novo Cliente
</a>
{% endblock %}

{% block content %}

<div class="card">
    <div class="card-header" style="padding: 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--color-border,#e2e8f0); flex-wrap: wrap; gap: 16px;">
        <form method="get" action="{{ route_to('painel.clientes') }}" style="display: flex; gap: 8px; width: 100%; max-width: 450px; margin: 0;">
            <div style="flex: 1; position: relative;">
                <input type="text" name="busca" class="form-control" value="{{ busca }}" placeholder="Buscar por nome, fantasia ou CPF/CNPJ..." style="width: 100%; height: 38px; padding: 0 12px; border: 1px solid var(--color-border,#cbd5e1); border-radius: 6px;">
            </div>
            <button type="submit" class="btn btn-primary" style="height: 38px; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 0 16px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                Buscar
            </button>
            {% if busca %}
            <a href="{{ route_to('painel.clientes') }}" class="btn btn-outline" style="height: 38px; display: flex; align-items: center; justify-content: center; padding: 0 16px; border: 1px solid var(--color-border,#cbd5e1); border-radius: 6px; text-decoration: none;">
                Limpar
            </a>
            {% endif %}
        </form>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>CPF/CNPJ</th>
                        <th>Nome Fantasia</th>
                        <th>Tipo</th>
                        <th>Situação</th>
                        <th style="width:120px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if clientes is empty %}
                    <tr>
                        <td colspan="6" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">
                            Nenhum cliente encontrado.
                        </td>
                    </tr>
                    {% else %}
                    {% for c in clientes %}
                    <tr>
                        <td>
                            <div class="user-name">{{ c.NOME }}</div>
                        </td>
                        <td>{{ c.CPF_CNPJ ? cnpjCpf(c.CPF_CNPJ) : '—' }}</td>
                        <td>{{ c.NOME_FANTASIA }}</td>
                        <td>{{ c.TIPO_DESCRICAO ?? '—' }}</td>
                        <td>
                            {% if c.SITUACAO_COR %}
                            <span class="status" style="background:{{ c.SITUACAO_COR }}18;color:{{ c.SITUACAO_COR }}">
                                <span class="status-dot" style="background:{{ c.SITUACAO_COR }}"></span>
                                {{ c.SITUACAO_DESCRICAO ?? c.SITUACAO_CODIGO }}
                            </span>
                            {% else %}
                            <span class="status status-active">
                                <span class="status-dot"></span>
                                Ativo
                            </span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-group">
                                <a href="{{ route_to('painel.clientes.visualizar', c.UUID) }}" class="btn btn-sm btn-outline" title="Visualizar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                </a>
                                <a href="{{ route_to('painel.clientes.editar', c.UUID) }}" class="btn btn-sm btn-outline" title="Editar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ route_to('painel.clientes.excluir', c.UUID) }}" class="inline-form" data-confirm="Tem certeza que deseja cancelar este cliente?">
                                    <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Cancelar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if pager and pager.getPageCount() > 1 %}
<div class="pagination">
    {{ pager.links()|raw }}
</div>
{% endif %}

{% endblock %}
