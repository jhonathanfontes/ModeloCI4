{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}
{% import 'Componentes/selectSituacao' as situacao %}
{% import 'Componentes/selectTipo' as tipo %}

{% block page_title %}{{ item ? 'Editar Produto' : 'Novo Produto' }}{% endblock %}
{% block page_heading %}{{ item ? 'Editar Produto' : 'Novo Produto' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.produtos') }}">Produtos</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Produto' : 'Novo Produto' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.produtos.salvar') }}">
            {% if item %}
                {{ forms.input('ID_PRODUTO', '', item.ID_PRODUTO, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ forms.input('NOME', 'Nome do Produto', old('NOME', item.NOME ?? ''), 'text', {
                    required: true,
                    col: 'col-12',
                    icon: 'fa-box',
                    placeholder: 'Ex: Camiseta Algodão Premium'
                }) }}

                {{ forms.textarea('DESCRICAO', 'Descrição', old('DESCRICAO', item.DESCRICAO ?? ''), {
                    col: 'col-12',
                    rows: 3,
                    placeholder: 'Descreva os detalhes do produto...'
                }) }}

                {{ forms.input('CODIGO_BARRAS', 'Código de Barras', old('CODIGO_BARRAS', item.CODIGO_BARRAS ?? ''), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-barcode',
                    placeholder: 'EAN / GTIN (Apenas números)'
                }) }}

                {{ forms.input('CODIGO_INTERNO', 'Código Interno (SKU)', old('CODIGO_INTERNO', item.CODIGO_INTERNO ?? ''), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-hashtag',
                    placeholder: 'Ex: PROD-100-M'
                }) }}

                {{ tipo.select('TIPO_ID', old('TIPO_ID', item.TIPO_ID ?? ''), 'TIPO_PRODUTO', '', { label: 'Tipo', col: 'col-6 col-md-12' }) }}

                {{ forms.input('PRECO_CUSTO', 'Preço de Custo (R$)', old('PRECO_CUSTO', item.PRECO_CUSTO ?? ''), 'number', {
                    col: 'col-4 col-md-12',
                    icon: 'fa-money-bill-transfer',
                    placeholder: '0.00',
                    min: 0,
                    step: 0.01
                }) }}

                {{ forms.input('PRECO_VENDA', 'Preço de Venda (R$)', old('PRECO_VENDA', item.PRECO_VENDA ?? ''), 'number', {
                    required: true,
                    col: 'col-4 col-md-12',
                    icon: 'fa-tag',
                    placeholder: '0.00',
                    min: 0,
                    step: 0.01
                }) }}

                {{ forms.input('ESTOQUE', 'Estoque Atual', old('ESTOQUE', item.ESTOQUE ?? ''), 'number', {
                    col: 'col-4 col-md-12',
                    icon: 'fa-cubes',
                    placeholder: '0',
                    min: 0,
                    step: 0.001
                }) }}

                {{ forms.select('UNIDADE', 'Unidade de Medida', old('UNIDADE', item.UNIDADE ?? ''), [
                    {value: 'UN', label: 'Unidade (UN)'},
                    {value: 'KG', label: 'Quilograma (KG)'},
                    {value: 'G', label: 'Grama (G)'},
                    {value: 'L', label: 'Litro (L)'},
                    {value: 'ML', label: 'Mililitro (ML)'},
                    {value: 'M', label: 'Metro (M)'},
                    {value: 'CX', label: 'Caixa (CX)'},
                    {value: 'PC', label: 'Peça (PC)'}
                ], {
                    col: 'col-6 col-md-12',
                    value_key: 'value',
                    text_key: 'label'
                }) }}

                {{ situacao.select('SITUACAO_ID', old('SITUACAO_ID', item.SITUACAO_ID ?? ''), 'SITUACAO_REGISTRO', '', { label: 'Situação', required: true, col: 'col-6 col-md-12' }) }}

                {{ forms.actions(route_to('painel.produtos'), item ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

{% endblock %}
