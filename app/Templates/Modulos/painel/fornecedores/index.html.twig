{% extends 'Layouts/painel' %}
{% block page_title %}Fornecedores{% endblock %}
{% block page_heading %}Fornecedores{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Fornecedores</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('painel.fornecedores.novo') }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Novo Fornecedor
</a>
{% endblock %}

{% block content %}

<div class="card">
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>CPF/CNPJ</th>
                        <th>E-mail</th>
                        <th>Telefone</th>
                        <th>Situação</th>
                        <th style="width:120px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if itens is empty %}
                    <tr>
                        <td colspan="6" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">
                            Nenhum fornecedor encontrado.
                        </td>
                    </tr>
                    {% else %}
                    {% for i in itens %}
                    <tr>
                        <td>
                            <div class="user-name">{{ i.NOME }}</div>
                        </td>
                        <td>{{ cnpjCpf(i.CPF_CNPJ) }}</td>
                        <td>{{ i.EMAIL }}</td>
                        <td>{{ telefone(i.TELEFONE) }}</td>
                        <td>
                            {% if i.SITUACAO_COR %}
                            <span class="status" style="background:{{ i.SITUACAO_COR }}18;color:{{ i.SITUACAO_COR }}">
                                <span class="status-dot" style="background:{{ i.SITUACAO_COR }}"></span>
                                {{ i.SITUACAO_DESCRICAO ?? i.SITUACAO_CODIGO }}
                            </span>
                            {% else %}
                            <span class="status status-active">
                                <span class="status-dot"></span>
                                Ativo
                            </span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-group">
                                <a href="{{ route_to('painel.fornecedores.editar', i.ID_FORNECEDOR) }}" class="btn btn-sm btn-outline" title="Editar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ route_to('painel.fornecedores.excluir', i.ID_FORNECEDOR) }}" class="inline-form" onsubmit="return confirm('Tem certeza que deseja cancelar este fornecedor?')">
                                    <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Cancelar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if pager and pager.getPageCount() > 1 %}
<div class="pagination">
    {{ pager.links()|raw }}
</div>
{% endif %}

{% endblock %}
