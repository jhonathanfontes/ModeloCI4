{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}
{% import 'Componentes/selectSituacao' as situacao %}
{% import 'Componentes/selectTipo' as tipo %}

{% block page_title %}{{ item ? 'Editar Fornecedor' : 'Novo Fornecedor' }}{% endblock %}
{% block page_heading %}{{ item ? 'Editar Fornecedor' : 'Novo Fornecedor' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.fornecedores') }}">Fornecedores</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Fornecedor' : 'Novo Fornecedor' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.fornecedores.salvar') }}">
            {% if item %}
                {{ forms.input('ID_FORNECEDOR', '', item.ID_FORNECEDOR, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ forms.input('NOME', 'Nome', old('NOME', item.NOME ?? ''), 'text', {
                    required: true,
                    col: 'col-6 col-md-12',
                    icon: 'fa-user',
                    placeholder: 'Razão Social / Nome completo'
                }) }}

                {{ forms.input('CPF_CNPJ', 'CPF/CNPJ', old('CPF_CNPJ', cnpjCpf(item.CPF_CNPJ ?? '')), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-address-card',
                    placeholder: 'CPF ou CNPJ (apenas números)',
                    mask: 'cpfCnpj'
                }) }}

                {{ tipo.select('TIPO_ID', old('TIPO_ID', item.TIPO_ID ?? ''), 'TIPO_PESSOA', '', { label: 'Tipo', col: 'col-6 col-md-12' }) }}

                {{ forms.input('EMAIL', 'E-mail', old('EMAIL', item.EMAIL ?? ''), 'email', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-envelope',
                    placeholder: 'contato@fornecedor.com'
                }) }}

                {{ forms.input('TELEFONE', 'Telefone', old('TELEFONE', telefone(item.TELEFONE ?? '')), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-phone',
                    placeholder: '(99) 9999-9999',
                    mask: 'telefone'
                }) }}

                {{ forms.input('CELULAR', 'Celular', old('CELULAR', celular(item.CELULAR ?? '')), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-mobile-screen-button',
                    placeholder: '(99) 99999-9999',
                    mask: 'celular'
                }) }}

                {{ situacao.select('SITUACAO_ID', old('SITUACAO_ID', item.SITUACAO_ID ?? ''), 'SITUACAO_REGISTRO', '', { label: 'Situação', required: true, col: 'col-6 col-md-12' }) }}

                {{ forms.actions(route_to('painel.fornecedores'), item ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const cnpjInput = document.getElementById('CPF_CNPJ');
        if (cnpjInput) {
            cnpjInput.addEventListener('blur', function() {
                const cnpj = this.value.replace(/\D/g, '');
                if (cnpj.length === 14) {
                    const fields = ['NOME', 'EMAIL', 'TELEFONE'];
                    fields.forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.placeholder = 'Carregando...';
                    });

                    fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`)
                        .then(response => {
                            if (!response.ok) throw new Error('CNPJ não encontrado ou erro na API');
                            return response.json();
                        })
                        .then(data => {
                            // Preencher tipo como Pessoa Jurídica
                            const tipoSelect = document.getElementById('TIPO_ID');
                            if (tipoSelect) {
                                for (let i = 0; i < tipoSelect.options.length; i++) {
                                    const text = tipoSelect.options[i].text.toLowerCase();
                                    const val = tipoSelect.options[i].value;
                                    if (text.includes('jurídica') || text.includes('juridica') || val == '2') {
                                        tipoSelect.value = val;
                                        tipoSelect.dispatchEvent(new Event('change'));
                                        break;
                                    }
                                }
                            }

                            // Preencher campos básicos
                            if (data.razao_social && document.getElementById('NOME')) {
                                document.getElementById('NOME').value = data.razao_social;
                                document.getElementById('NOME').dispatchEvent(new Event('input'));
                            }
                            if (data.email && document.getElementById('EMAIL')) {
                                document.getElementById('EMAIL').value = data.email;
                                document.getElementById('EMAIL').dispatchEvent(new Event('input'));
                            }
                            if (data.ddd_telefone_1 && document.getElementById('TELEFONE')) {
                                document.getElementById('TELEFONE').value = data.ddd_telefone_1;
                                document.getElementById('TELEFONE').dispatchEvent(new Event('input'));
                            }
                        })
                        .catch(err => {
                            console.error('Erro ao buscar CNPJ:', err);
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    title: 'Aviso',
                                    text: 'Não foi possível encontrar dados para este CNPJ automaticamente.',
                                    icon: 'info',
                                    confirmButtonText: 'Ok'
                                });
                            } else {
                                alert('Não foi possível encontrar dados para este CNPJ automaticamente.');
                            }
                        })
                        .finally(() => {
                            fields.forEach(id => {
                                const el = document.getElementById(id);
                                if (el) el.placeholder = '';
                            });
                        });
                }
            });
        }
    });
</script>
{% endblock %}
{% endblock %}
