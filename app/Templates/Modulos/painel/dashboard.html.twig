{% extends 'Layouts/painel' %}
{% block page_title %}Dashboard{% endblock %}
{% block page_heading %}Dashboard{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
{% endblock %}

{% block content %}

{% if empresaAtiva %}

<div class="welcome-card">
    <h2>Bem-vindo, {{ usuario.nome }}!</h2>
    <p>Empresa ativa: <strong>{{ empresaAtiva.nome }}</strong></p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#eef2ff;color:#4f46e5;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">—</span>
            <span class="stat-label">Empresas</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:#fef2f2;color:#dc2626;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">—</span>
            <span class="stat-label">Clientes</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:#f0fdf4;color:#16a34a;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">—</span>
            <span class="stat-label">Ativos</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:#fffbeb;color:#d97706;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">—</span>
            <span class="stat-label">Notificações</span>
        </div>
    </div>
</div>

{% elseif empresas|length > 0 %}

<div class="welcome-card">
    <h2>Bem-vindo, {{ usuario.nome }}!</h2>
    <p>Selecione uma empresa para acessar o painel:</p>
</div>

<div class="empresa-grid">
    {% for e in empresas %}
    <a href="{{ route_to('painel.empresa.ativar', e.EMPRESA_ID) }}" class="empresa-card">
        <div class="empresa-card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
        </div>
        <div class="empresa-card-info">
            <span class="empresa-card-nome">{{ e.EMPRESA_NOME }}</span>
            {% if e.PERFIL_NOME %}
            <span class="empresa-card-perfil">{{ e.PERFIL_NOME }}</span>
            {% endif %}
        </div>
        <svg class="empresa-card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
        </svg>
    </a>
    {% endfor %}
</div>

{% else %}

<div class="welcome-card">
    <h2>Bem-vindo, {{ usuario.nome }}!</h2>
    <p>Você ainda não possui empresas vinculadas.</p>
</div>

<div class="card">
    <div class="card-body" style="text-align:center;padding:48px 24px;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:16px;">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
        </svg>
        <p style="color:var(--color-text-muted);font-size:15px;">Entre em contato com o administrador para vincular sua conta a uma empresa.</p>
    </div>
</div>

{% endif %}

{% endblock %}
