{% extends 'Layouts/painel' %}
{% block page_title %}{{ item ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}
{% block page_heading %}{{ item ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.servicos-cadastro') }}">Serviços</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Serviço' : 'Novo Serviço' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.servicos-cadastro.salvar') }}">
            {% if item %}
            <input type="hidden" name="ID_SERVICO" value="{{ item.ID_SERVICO }}">
            {% endif %}

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="NOME">Nome</label>
                    <input type="text" id="NOME" name="NOME" class="form-control" value="{{ old('NOME', item.NOME ?? '') }}" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="DESCRICAO">Descrição</label>
                    <textarea id="DESCRICAO" name="DESCRICAO" class="form-control" rows="3">{{ old('DESCRICAO', item.DESCRICAO ?? '') }}</textarea>
                </div>

                <div class="form-group">
                    <label class="form-label" for="PRECO">Preço (R$)</label>
                    <input type="number" id="PRECO" name="PRECO" class="form-control" value="{{ old('PRECO', item.PRECO ?? '') }}" step="0.01" min="0" placeholder="0,00" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="DURACAO_MINUTOS">Duração (minutos)</label>
                    <input type="number" id="DURACAO_MINUTOS" name="DURACAO_MINUTOS" class="form-control" value="{{ old('DURACAO_MINUTOS', item.DURACAO_MINUTOS ?? '') }}" min="0" placeholder="Deixe em branco para não informado">
                </div>

                <div class="form-group">
                    <label class="form-label" for="SITUACAO_ID">Situação</label>
                    <select id="SITUACAO_ID" name="SITUACAO_ID" class="form-control" required>
                        <option value="">— Selecione —</option>
                        {% for s in situacoes %}
                        <option value="{{ s.ID_SITUACAO }}" {{ (old('SITUACAO_ID', item.SITUACAO_ID ?? '') == s.ID_SITUACAO) ? 'selected' : '' }}>
                            {{ s.DESCRICAO }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ route_to('painel.servicos-cadastro') }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    {{ item ? 'Atualizar' : 'Salvar' }}
                </button>
            </div>
        </form>
    </div>
</div>

{% endblock %}
