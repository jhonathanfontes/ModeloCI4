{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}
{% import 'Componentes/selectSituacao' as situacao %}
{% import 'Componentes/selectTipo' as tipo %}

{% block page_title %}{{ item ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}
{% block page_heading %}{{ item ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.servicos-cadastro') }}">Serviços</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Serviço' : 'Novo Serviço' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.servicos-cadastro.salvar') }}">
            {% if item %}
                {{ forms.input('ID_SERVICO', '', item.ID_SERVICO, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ forms.input('NOME', 'Nome do Serviço', old('NOME', item.NOME ?? ''), 'text', {
                    required: true,
                    col: 'col-12',
                    icon: 'fa-screwdriver-wrench',
                    placeholder: 'Ex: Instalação de Ar Condicionado'
                }) }}

                {{ forms.textarea('DESCRICAO', 'Descrição', old('DESCRICAO', item.DESCRICAO ?? ''), {
                    col: 'col-12',
                    rows: 3,
                    placeholder: 'Descreva os detalhes do serviço prestado...'
                }) }}

                {{ forms.input('PRECO', 'Preço Cobrado (R$)', old('PRECO', item.PRECO ?? ''), 'number', {
                    required: true,
                    col: 'col-4 col-md-12',
                    icon: 'fa-tag',
                    placeholder: '0.00',
                    min: 0,
                    step: 0.01
                }) }}

                {{ forms.input('DURACAO_MINUTOS', 'Duração Estimada (minutos)', old('DURACAO_MINUTOS', item.DURACAO_MINUTOS ?? ''), 'number', {
                    col: 'col-4 col-md-12',
                    icon: 'fa-clock',
                    placeholder: 'Ex: 60',
                    min: 0
                }) }}

                {{ tipo.select('TIPO_ID', old('TIPO_ID', item.TIPO_ID ?? ''), 'TIPO_SERVICO', '', { label: 'Tipo', col: 'col-6 col-md-12' }) }}

                {{ situacao.select('SITUACAO_ID', old('SITUACAO_ID', item.SITUACAO_ID ?? ''), 'SITUACAO_REGISTRO', '', { label: 'Situação', required: true, col: 'col-4 col-md-12' }) }}

                {{ forms.actions(route_to('painel.servicos-cadastro'), item ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

{% endblock %}
