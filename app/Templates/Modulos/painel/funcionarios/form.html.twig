{% extends 'Layouts/painel' %}
{% import 'Componentes/form.html.twig' as forms %}
{% import 'Componentes/selectSituacao' as situacao %}
{% import 'Componentes/selectTipo' as tipo %}

{% block page_title %}{{ item ? 'Editar Funcionário' : 'Novo Funcionário' }}{% endblock %}
{% block page_heading %}{{ item ? 'Editar Funcionário' : 'Novo Funcionário' }}{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('painel.dashboard') }}">Painel</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('painel.funcionarios') }}">Funcionários</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span>
{% endblock %}

{% block content %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Funcionário' : 'Novo Funcionário' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('painel.funcionarios.salvar') }}">
            {% if item %}
                {{ forms.input('ID_FUNCIONARIO', '', item.ID_FUNCIONARIO, 'hidden') }}
            {% endif %}

            <div class="form-grid">
                {{ forms.input('NOME', 'Nome', old('NOME', item.NOME ?? ''), 'text', {
                    required: true,
                    col: 'col-6 col-md-12',
                    icon: 'fa-user',
                    placeholder: 'Nome completo'
                }) }}

                {{ forms.input('EMAIL', 'E-mail', old('EMAIL', item.EMAIL ?? ''), 'email', {
                    required: true,
                    col: 'col-6 col-md-12',
                    icon: 'fa-envelope',
                    placeholder: 'usuario@empresa.com'
                }) }}

                {{ forms.input('CARGO', 'Cargo', old('CARGO', item.CARGO ?? ''), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-briefcase',
                    placeholder: 'Ex: Gerente de Vendas'
                }) }}

                {{ tipo.select('TIPO_ID', old('TIPO_ID', item.TIPO_ID ?? ''), 'TIPO_FUNCIONARIO', '', { label: 'Tipo', col: 'col-6 col-md-12' }) }}

                {% set selectedDepto = old('DEPARTAMENTO_ID', item.DEPARTAMENTO_ID ?? '') %}
                {{ forms.select('DEPARTAMENTO_ID', 'Departamento', selectedDepto, departamentos, {
                    col: 'col-6 col-md-12',
                    empty_option: '-- Selecione --',
                    value_key: 'ID_DEPARTAMENTO',
                    text_key: 'NOME'
                }) }}

                {{ forms.input('TELEFONE', 'Telefone', old('TELEFONE', telefone(item.TELEFONE ?? '')), 'text', {
                    col: 'col-6 col-md-12',
                    icon: 'fa-phone',
                    placeholder: '(99) 9999-9999',
                    mask: 'telefone'
                }) }}

                {{ situacao.select('SITUACAO_ID', old('SITUACAO_ID', item.SITUACAO_ID ?? ''), 'SITUACAO_REGISTRO', '', { label: 'Situação', required: true, col: 'col-6 col-md-12' }) }}

                {{ forms.actions(route_to('painel.funcionarios'), item ? 'Atualizar' : 'Salvar') }}
            </div>
        </form>
    </div>
</div>

{% endblock %}
