{% extends 'Layouts/admin' %}

{% block page_title %}Situações{% endblock %}
{% block page_heading %}Situações{% endblock %}

{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Situações</span>
{% endblock %}

{% block page_actions %}
<a href="{{ route_to('admin.situacoes.novo') }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Nova Situação
</a>
{% endblock %}

{% block content %}
{% if success %}<div class="alert alert-success">{{ success }}</div>{% endif %}
{% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}

<div class="card">
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Módulo</th>
                        <th>Código</th>
                        <th>Descrição</th>
                        <th>Cor</th>
                        <th>Flags</th>
                        <th style="width:100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if situacoes is empty %}
                    <tr>
                        <td colspan="6" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">
                            Nenhuma situação encontrada.
                        </td>
                    </tr>
                    {% else %}
                    {% for s in situacoes %}
                    <tr>
                        <td><code>{{ s.MODULO }}</code></td>
                        <td><strong>{{ s.CODIGO }}</strong></td>
                        <td>{{ s.DESCRICAO }}</td>
                        <td>
                            {% if s.COR %}
                            <span class="status" style="background:{{ s.COR }}18;color:{{ s.COR }}">
                                <span class="status-dot" style="background:{{ s.COR }}"></span>
                                {{ s.COR }}
                            </span>
                            {% else %}
                            —
                            {% endif %}
                        </td>
                        <td>
                            {% set flags = [] %}
                            {% if s.FINALIZADO %}{% set flags = flags|merge(['Finalizado']) %}{% endif %}
                            {% if s.CONCLUIDA %}{% set flags = flags|merge(['Concluída']) %}{% endif %}
                            {% if s.CANCELADA %}{% set flags = flags|merge(['Cancelada']) %}{% endif %}
                            {% if s.PENDENTE %}{% set flags = flags|merge(['Pendente']) %}{% endif %}
                            {% if s.BLOQUEIA_EDICAO %}{% set flags = flags|merge(['Bloq.Ed']) %}{% endif %}
                            {% if s.GERA_HISTORICO %}{% set flags = flags|merge(['Histórico']) %}{% endif %}
                            {% if flags is empty %}
                            <span style="color:var(--color-text-muted)">—</span>
                            {% else %}
                            {{ flags|join(', ') }}
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-group">
                                <a href="{{ route_to('admin.situacoes.editar', s.UUID) }}" class="btn btn-sm btn-outline" title="Editar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ route_to('admin.situacoes.excluir', s.UUID) }}" class="inline-form" data-confirm="Tem certeza que deseja excluir esta situação?">
                                    {{ csrf_field()|raw }}
                                    <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Excluir">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
