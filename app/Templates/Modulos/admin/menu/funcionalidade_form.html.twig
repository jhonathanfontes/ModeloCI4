{% extends 'Layouts/admin' %}
{% block page_title %}{{ funcionalidade ? 'Editar Funcionalidade' : 'Nova Funcionalidade' }}{% endblock %}
{% block page_heading %}{{ funcionalidade ? 'Editar Funcionalidade' : 'Nova Funcionalidade' }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.menu') }}">Menu</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.menu.funcionalidades', servico.id) }}">{{ servico.nome }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ funcionalidade ? 'Editar' : 'Nova' }}</span>
{% endblock %}
{% block page_actions %}{% endblock %}

{% block content %}
{% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}
{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}<li>{{ msg }}</li>{% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header"><h3>{{ funcionalidade ? 'Editar Funcionalidade' : 'Nova Funcionalidade' }}</h3></div>
    <div class="card-body">
        <form method="post" action="{{ route_to('admin.menu.funcionalidade.salvar') }}">
            {% if funcionalidade %}<input type="hidden" name="ID_FUNCIONALIDADE" value="{{ funcionalidade.id }}">{% endif %}
            <input type="hidden" name="SERVICO_ID" value="{{ servico.id }}">

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="NOME">Nome</label>
                    <input type="text" id="NOME" name="NOME" class="form-control" value="{{ old('NOME', funcionalidade.nome ?? '') }}" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="CHAVE">Chave</label>
                    <input type="text" id="CHAVE" name="CHAVE" class="form-control" value="{{ old('CHAVE', funcionalidade.chave ?? '') }}" placeholder="Ex: empresa.criar" required>
                </div>
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label" for="DESCRICAO">Descrição</label>
                    <textarea id="DESCRICAO" name="DESCRICAO" class="form-control" rows="3">{{ old('DESCRICAO', funcionalidade.descricao ?? '') }}</textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" for="SITUACAO_ID">Situação</label>
                    <select id="SITUACAO_ID" name="SITUACAO_ID" class="form-control" required>
                        {% for s in situacoes %}
                        <option value="{{ s.ID_SITUACAO }}" {{ (old('SITUACAO_ID', funcionalidade.situacaoId ?? '') == s.ID_SITUACAO) ? 'selected' : '' }}>{{ s.DESCRICAO }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ route_to('admin.menu.funcionalidades', servico.id) }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">{{ funcionalidade ? 'Atualizar' : 'Salvar' }}</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
