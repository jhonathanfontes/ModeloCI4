{% extends 'Layouts/admin' %}
{% block page_title %}Gerenciar Menu{% endblock %}
{% block page_heading %}Gerenciar Menu{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Menu</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('admin.menu.modulo.novo') }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Novo Módulo
</a>
{% endblock %}

{% block content %}

{% if success %}
<div class="alert alert-success">{{ success }}</div>
{% endif %}

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

<div class="card">
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Módulo</th>
                    <th>Ícone</th>
                    <th>Rota</th>
                    <th>Ordem</th>
                    <th>Serviços</th>
                    <th>Situação</th>
                    <th style="width:160px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                {% if modulos|length > 0 %}
                {% for m in modulos %}
                <tr>
                    <td>
                        <strong>{{ m.nome }}</strong>
                        {% if m.descricao %}
                        <br><small style="color:var(--color-text-muted);">{{ m.descricao }}</small>
                        {% endif %}
                    </td>
                    <td>{% if m.icone %}<i class="{{ m.icone }}"></i>{% else %}—{% endif %}</td>
                    <td>{% if m.urlRota %}<code>{{ m.urlRota }}</code>{% else %}<span style="color:var(--color-text-muted);">—</span>{% endif %}</td>
                    <td>{{ m.ordem ?: '—' }}</td>
                    <td>
                        <a href="{{ route_to('admin.menu.servicos', m.uuid) }}" class="btn btn-sm btn-outline" style="font-weight:600;">
                            {{ m.servicos|length }} serviço{{ m.servicos|length != 1 ? 's' }}
                        </a>
                    </td>
                    <td>
                        {% if m.situacaoCor %}
                        <span class="status" style="background:{{ m.situacaoCor }}18;color:{{ m.situacaoCor }};font-size:11px;padding:2px 8px;">
                            <span class="status-dot" style="background:{{ m.situacaoCor }}"></span>
                            {{ m.situacaoDescricao }}
                        </span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="action-group">
                            <a href="{{ route_to('admin.menu.modulo.editar', m.uuid) }}" class="btn btn-sm btn-outline" title="Editar">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ route_to('admin.menu.modulo.excluir', m.uuid) }}" class="inline-form" data-confirm="Tem certeza que deseja cancelar este módulo?">
                                    {{ csrf_field()|raw }}
                                <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Cancelar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">Nenhum módulo cadastrado.</td>
                </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
