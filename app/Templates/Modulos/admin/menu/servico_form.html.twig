{% extends 'Layouts/admin' %}
{% block page_title %}{{ servico ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}
{% block page_heading %}{{ servico ? 'Editar Serviço' : 'Novo Serviço' }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.menu') }}">Menu</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.menu.servicos', modulo.uuid) }}">{{ modulo.nome }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ servico ? 'Editar' : 'Novo' }}</span>
{% endblock %}
{% block page_actions %}{% endblock %}

{% block content %}
{% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}
{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}<li>{{ msg }}</li>{% endfor %}
    </ul>
</div>
{% endif %}

<div class="card">
    <div class="card-header"><h3>{{ servico ? 'Editar Serviço' : 'Novo Serviço' }}</h3></div>
    <div class="card-body">
        <form method="post" action="{{ route_to('admin.menu.servico.salvar') }}">
            {{ csrf_field()|raw }}
            {% if servico %}<input type="hidden" name="ID_SERVICO" value="{{ servico.id }}">{% endif %}
            <input type="hidden" name="MODULO_ID" value="{{ modulo.id }}">

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="NOME">Nome</label>
                    <input type="text" id="NOME" name="NOME" class="form-control" value="{{ old('NOME', servico.nome ?? '') }}" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="ICONE">Ícone</label>
                    {% include 'Modulos/admin/menu/_icon_picker' with {
                        fieldId: 'ICONE',
                        fieldName: 'ICONE',
                        fieldValue: old('ICONE', servico.icone ?? ''),
                        placeholder: 'Ex: fas fa-users',
                    } %}
                </div>
                <div class="form-group">
                    <label class="form-label" for="URL_MODULO">URL do Módulo</label>
                    <input type="text" id="URL_MODULO" name="URL_MODULO" class="form-control" value="{{ old('URL_MODULO', servico.urlModulo ?? '') }}">
                </div>
                <div class="form-group">
                    <label class="form-label" for="URL_ROTA">URL da Rota</label>
                    <div style="display:flex;align-items:center;gap:4px;">
                        <input type="text" id="URL_ROTA" name="URL_ROTA" class="form-control" value="{{ old('URL_ROTA', servico.urlRota ?? '') }}" style="flex:1;">
                        <button type="button" class="btn btn-sm btn-outline" onclick="gerarUrlRota()" title="Gerar automaticamente">⟳</button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="ORDEM">Ordem</label>
                    <input type="number" id="ORDEM" name="ORDEM" class="form-control" value="{{ old('ORDEM', servico.ordem ?? '') }}">
                </div>
                <div class="form-group">
                    <label class="form-label" for="DASHBOARD">
                        <input type="checkbox" id="DASHBOARD" name="DASHBOARD" value="1" {{ old('DASHBOARD', servico.dashboard ?? '') ? 'checked' : '' }}>
                        Exibir no Dashboard
                    </label>
                </div>
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label" for="DESCRICAO">Descrição</label>
                    <textarea id="DESCRICAO" name="DESCRICAO" class="form-control" rows="3">{{ old('DESCRICAO', servico.descricao ?? '') }}</textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" for="SITUACAO_ID">Situação</label>
                    <select id="SITUACAO_ID" name="SITUACAO_ID" class="form-control" required>
                        {% for s in situacoes %}
                        <option value="{{ s.ID_SITUACAO }}" {{ (old('SITUACAO_ID', situacaoId ?? '') == s.ID_SITUACAO) ? 'selected' : '' }}>{{ s.DESCRICAO }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ route_to('admin.menu.servicos', modulo.uuid) }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">{{ servico ? 'Atualizar' : 'Salvar' }}</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function slugify(texto) {
    return texto
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
}

function gerarUrlRota() {
    const urlModulo = document.getElementById('URL_MODULO').value.trim().replace(/\/+$/g, '');
    const nome = document.getElementById('NOME').value.trim();
    const moduloNome = '{{ modulo.nome|e('js') }}';
    if (nome) {
        const baseUrl = urlModulo || '/' + slugify(moduloNome);
        document.getElementById('URL_ROTA').value = baseUrl + '/' + slugify(nome);
    }
}

document.addEventListener('DOMContentLoaded', function () {
    const nomeInput = document.getElementById('NOME');
    const urlRotaInput = document.getElementById('URL_ROTA');

    urlRotaInput.dataset.auto = '1';

    function autoGerar() {
        if (nomeInput.value.trim()) {
            gerarUrlRota();
        }
    }

    nomeInput.addEventListener('blur', autoGerar);
    document.getElementById('URL_MODULO').addEventListener('blur', autoGerar);
});
</script>
{% endblock %}
