{% extends 'Layouts/admin' %}
{% block page_title %}Serviços: {{ modulo.nome }}{% endblock %}
{% block page_heading %}Serviços: {{ modulo.nome }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.menu') }}">Menu</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ modulo.nome }}</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('admin.menu.servico.novo', modulo.id) }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Novo Serviço
</a>
{% endblock %}

{% block content %}
{% if success %}<div class="alert alert-success">{{ success }}</div>{% endif %}
{% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}

<div class="card">
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Rota</th>
                        <th>Ícone</th>
                        <th>Ordem</th>
                        <th>Dashboard</th>
                        <th>Situação</th>
                        <th style="width:160px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if servicos is empty %}
                    <tr><td colspan="7" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">Nenhum serviço neste módulo.</td></tr>
                    {% else %}
                    {% for s in servicos %}
                    <tr>
                        <td><strong>{{ s.nome }}</strong>{% if s.descricao %}<br><small style="color:var(--color-text-muted);">{{ s.descricao }}</small>{% endif %}</td>
                        <td>{% if s.urlRota %}<code>{{ s.urlRota }}</code>{% else %}<span style="color:var(--color-text-muted);">—</span>{% endif %}</td>
                        <td>{% if s.icone %}<i class="{{ s.icone }}"></i>{% else %}—{% endif %}</td>
                        <td>{{ s.ordem ?: '—' }}</td>
                        <td>{{ s.dashboard ? '✓' : '—' }}</td>
                        <td>{% if s.situacaoCor %}<span class="status" style="background:{{ s.situacaoCor }}18;color:{{ s.situacaoCor }};font-size:11px;padding:2px 8px;"><span class="status-dot" style="background:{{ s.situacaoCor }}"></span>{{ s.situacaoDescricao }}</span>{% endif %}</td>
                        <td>
                            <div class="action-group">
                                <a href="{{ route_to('admin.menu.funcionalidades', s.id) }}" class="btn btn-sm btn-outline" title="Funcionalidades">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                </a>
                                <a href="{{ route_to('admin.menu.servico.editar', s.id) }}" class="btn btn-sm btn-outline" title="Editar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                                <form method="post" action="{{ route_to('admin.menu.servico.copiar', s.id) }}" class="inline-form">
                                    <button type="submit" class="btn btn-sm btn-outline" title="Copiar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                    </button>
                                </form>
                                <form method="post" action="{{ route_to('admin.menu.servico.excluir', s.id) }}" class="inline-form" onsubmit="return confirm('Tem certeza que deseja cancelar este serviço?')">
                                    <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Cancelar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if pager and pager.getPageCount() > 1 %}
<div class="pagination">{{ pager.links()|raw }}</div>
{% endif %}

<div style="margin-top:16px;">
    <a href="{{ route_to('admin.menu') }}" class="btn btn-outline">← Voltar para Módulos</a>
</div>
{% endblock %}
