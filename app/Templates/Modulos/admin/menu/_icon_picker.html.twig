<div class="icon-picker-wrapper" style="display:flex;align-items:center;">
    <input type="text" id="{{ fieldId ?? 'ICONE' }}" name="{{ fieldName ?? 'ICONE' }}" class="form-control" value="{{ fieldValue ?? '' }}" placeholder="{{ placeholder ?? 'Ex: fas fa-users' }}" style="flex:1;">
    <button type="button" class="icon-picker-trigger" onclick="openIconPicker('{{ fieldId ?? 'ICONE' }}')">
        <i class="fas fa-icons"></i>
        Ícones
    </button>
</div>

<div class="modal-overlay" id="iconPickerModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Selecionar Ícone</h3>
            <button type="button" class="modal-close" onclick="closeIconPicker()">&times;</button>
        </div>
        <div class="modal-search">
            <input type="text" id="iconSearch" oninput="filterIcons()" placeholder="Buscar ícone..." autofocus>
        </div>
        <div class="modal-body" id="iconModalBody">
            {% for categoria, icones in categorias %}
            <div class="icon-category">
                <h4 style="font-size:13px;color:var(--color-text-muted);margin:16px 0 8px;text-transform:uppercase;letter-spacing:0.5px;">{{ categoria }}</h4>
                <div class="icon-grid">
                    {% for icone in icones %}
                    <div class="icon-grid-item" data-icon="{{ icone }}" onclick="selectIcon(this)" title="{{ icone }}">
                        <i class="{{ icone }}"></i>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
let activeIconField = '{{ fieldId ?? 'ICONE' }}';

function openIconPicker(fieldId) {
    activeIconField = fieldId;
    const modal = document.getElementById('iconPickerModal');
    modal.classList.add('active');
    document.getElementById('iconSearch').value = '';
    filterIcons();
    document.getElementById('iconSearch').focus();

    const currentVal = document.getElementById(fieldId).value.trim();
    document.querySelectorAll('.icon-grid-item').forEach(el => {
        el.classList.toggle('selected', el.dataset.icon === currentVal);
    });

    document.body.style.overflow = 'hidden';
}

function closeIconPicker() {
    document.getElementById('iconPickerModal').classList.remove('active');
    document.body.style.overflow = '';
}

function selectIcon(el) {
    const iconClass = el.dataset.icon;
    document.getElementById(activeIconField).value = iconClass;
    document.querySelectorAll('.icon-grid-item').forEach(i => i.classList.remove('selected'));
    el.classList.add('selected');
    setTimeout(closeIconPicker, 200);
}

function filterIcons() {
    const q = document.getElementById('iconSearch').value.toLowerCase().trim();
    document.querySelectorAll('.icon-category').forEach(cat => {
        let hasVisible = false;
        cat.querySelectorAll('.icon-grid-item').forEach(item => {
            const match = !q || item.dataset.icon.includes(q);
            item.style.display = match ? '' : 'none';
            if (match) hasVisible = true;
        });
        cat.style.display = hasVisible || !q ? '' : 'none';
    });
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeIconPicker();
});

document.getElementById('iconPickerModal').addEventListener('click', function(e) {
    if (e.target === this) closeIconPicker();
});
</script>
