{% extends 'Layouts/admin' %}
{% block page_title %}{{ empresa.nomeFantasia }}{% endblock %}
{% block page_heading %}{{ empresa.nomeFantasia }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas') }}">Empresas</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ empresa.nomeFantasia }}</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('admin.empresas.editar', empresa.id) }}" class="btn btn-outline">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Editar
</a>
{% endblock %}

{% block content %}

{% if success %}
<div class="alert alert-success">{{ success }}</div>
{% endif %}

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

<div class="tabs">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.id) }}" class="tab tab-active">Dados</a>
    <a href="{{ route_to('admin.empresas.usuarios', empresa.id) }}" class="tab">Usuários ({{ usuarios|length }})</a>
    <a href="#" class="tab disabled">Serviços</a>
</div>

<div class="card">
    <div class="card-header">
        <h3>Informações da Empresa</h3>
    </div>
    <div class="card-body">
        <div class="view-grid">
            <div class="view-group">
                <span class="view-label">Razão Social</span>
                <span class="view-value">{{ empresa.razaoSocial }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">Nome Fantasia</span>
                <span class="view-value">{{ empresa.nomeFantasia }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">CPF/CNPJ</span>
                <span class="view-value">{{ cnpjCpf(empresa.cpfCnpj) }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">E-mail</span>
                <span class="view-value">{{ empresa.email }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">Telefone</span>
                <span class="view-value">{{ empresa.telefone ? telefone(empresa.telefone) : '-' }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">Celular</span>
                <span class="view-value">{{ empresa.celular ? celular(empresa.celular) : '-' }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">Situação</span>
                <span class="view-value">
                    {% if empresa.situacaoCor %}
                    <span class="status" style="background:{{ empresa.situacaoCor }}18;color:{{ empresa.situacaoCor }}">
                        <span class="status-dot" style="background:{{ empresa.situacaoCor }}"></span>
                        {{ empresa.situacaoDescricao ?? empresa.situacaoCodigo }}
                    </span>
                    {% else %}
                    <span class="status status-active">
                        <span class="status-dot"></span>
                        Ativo
                    </span>
                    {% endif %}
                </span>
            </div>

            <div class="view-group">
                <span class="view-label">Criado em</span>
                <span class="view-value">{{ dataBR(empresa.criadoEm) }}</span>
            </div>

            <div class="view-group">
                <span class="view-label">Atualizado em</span>
                <span class="view-value">{{ dataBR(empresa.atualizadoEm) }}</span>
            </div>
        </div>
    </div>
</div>

{% endblock %}
