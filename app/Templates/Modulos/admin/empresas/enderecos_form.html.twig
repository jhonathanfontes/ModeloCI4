{% extends 'Layouts/admin' %} {% block page_title %}{{ item ? 'Editar Endereço' : 'Novo Endereço' }} - {{ empresa.nomeFantasia }}{% endblock %} {% block page_heading %}{{ item ? 'Editar Endereço' : 'Novo Endereço' }} - {{ empresa.nomeFantasia }}{% endblock
%} {% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas') }}">Empresas</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}">{{ empresa.nomeFantasia }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas.enderecos', empresa.uuid) }}">Endereços</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ item ? 'Editar' : 'Novo' }}</span> {% endblock %} {% block page_actions %}{% endblock %} {% block content %} {% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %} {% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
        {% for field, msg in errors %}
        <li>{{ msg }}</li>
        {% endfor %}
    </ul>
</div>
{% endif %}

<div class="tabs">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}" class="tab">Dados</a>
    <a href="{{ route_to('admin.empresas.enderecos', empresa.uuid) }}" class="tab tab-active">Endereços</a>
    <a href="{{ route_to('admin.empresas.contatos', empresa.uuid) }}" class="tab">Contatos</a>
    <a href="{{ route_to('admin.empresas.usuarios', empresa.uuid) }}" class="tab">Usuários</a>
    <a href="{{ route_to('admin.empresas.servicos', empresa.uuid) }}" class="tab">Serviços</a>
</div>

<div class="card">
    <div class="card-header">
        <h3>{{ item ? 'Editar Endereço' : 'Novo Endereço' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('admin.empresas.enderecos.salvar', empresa.uuid) }}">
            {{ csrf_field()|raw }} {% if item %}
            <input type="hidden" name="ID_ENDERECO" value="{{ item.ID_ENDERECO }}"> {% endif %}

            <div class="form-grid" style="grid-template-columns:repeat(12,1fr);gap:8px;">
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" for="TIPO_ID">Tipo de Endereço</label>
                    <select id="TIPO_ID" name="TIPO_ID" class="form-control">
                        <option value="">— Selecione —</option>
                        {% for t in dominio_tipos('TIPO_ENDERECO', 'COMERCIAL,ENTREGA') %}
                        <option value="{{ t.CODIGO }}" {{ (old('TIPO_ID', item.CODIGO ?? '') == t.CODIGO) ? 'selected' : '' }}>
                            {{ t.DESCRICAO }}
                        </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" for="CEP">CEP</label>
                    <input type="text" id="CEP" name="CEP" class="form-control" value="{{ old('CEP', cep(item.CEP ?? '')) }}" data-mask="cep" placeholder="99.999-999">
                </div>

                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" for="NUMERO">Número</label>
                    <input type="text" id="NUMERO" name="NUMERO" class="form-control" value="{{ old('NUMERO', item.NUMERO ?? '') }}" required>
                </div>

                <div class="form-group" style="grid-column:span 6;">
                    <label class="form-label" for="LOGRADOURO">Logradouro</label>
                    <input type="text" id="LOGRADOURO" name="LOGRADOURO" class="form-control" value="{{ old('LOGRADOURO', item.LOGRADOURO ?? '') }}" required>
                </div>

                <div class="form-group" style="grid-column:span 12;">
                    <label class="form-label" for="COMPLEMENTO">Complemento</label>
                    <input type="text" id="COMPLEMENTO" name="COMPLEMENTO" class="form-control" value="{{ old('COMPLEMENTO', item.COMPLEMENTO ?? '') }}">
                </div>

                <div class="form-group" style="grid-column:span 4;">
                    <label class="form-label" for="BAIRRO">Bairro</label>
                    <input type="text" id="BAIRRO" name="BAIRRO" class="form-control" value="{{ old('BAIRRO', item.BAIRRO ?? '') }}" required>
                </div>

                <div class="form-group" style="grid-column:span 4;">
                    <label class="form-label" for="CIDADE">Cidade</label>
                    <input type="text" id="CIDADE" name="CIDADE" class="form-control" value="{{ old('CIDADE', item.CIDADE ?? '') }}" required>
                </div>

                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" for="UF">UF</label>
                    <select id="UF" name="UF" class="form-control" required>
                        <option value="">Selecione</option>
                        {% for uf in ['AC', 'AL', 'AP', 'AM', 'BA', 'CE', 'DF', 'ES', 'GO', 'MA', 'MT', 'MS', 'MG', 'PA', 'PB', 'PR', 'PE', 'PI', 'RJ', 'RN', 'RS', 'RO', 'RR', 'SC', 'SP', 'SE', 'TO'] %}
                        <option value="{{ uf }}" {{ (old('UF', item.UF ?? '') == uf) ? 'selected' : '' }}>{{ uf }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group" style="grid-column:span 2;justify-content:center;">
                    <label class="toggle-switch" style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-top:6px;">
                        <input type="hidden" name="PRINCIPAL" value="0">
                        <input type="checkbox" name="PRINCIPAL" value="1" {{ (old('PRINCIPAL', item.PRINCIPAL ?? '') == '1' or (item is null and enderecos is empty)) ? 'checked' : '' }} style="width:18px;height:18px;accent-color:var(--color-primary);">
                        <span style="font-size:14px;color:var(--color-text);white-space:nowrap;">Principal</span>
                    </label>
                </div>

            </div>

            <div class="form-actions">
                <a href="{{ route_to('admin.empresas.enderecos', empresa.uuid) }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">{{ item ? 'Atualizar' : 'Salvar' }}</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const cepInput = document.getElementById('CEP');
        if (cepInput) {
            cepInput.addEventListener('blur', function() {
                const cep = this.value.replace(/\D/g, '');
                if (cep.length === 8) {
                    const fields = ['LOGRADOURO', 'BAIRRO', 'CIDADE', 'UF'];
                    fields.forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.placeholder = 'Carregando...';
                    });

                    fetch('https://viacep.com.br/ws/' + cep + '/json/')
                        .then(response => response.json())
                        .then(data => {
                            if (!data.erro) {
                                if (document.getElementById('LOGRADOURO')) {
                                    document.getElementById('LOGRADOURO').value = data.logradouro;
                                    document.getElementById('LOGRADOURO').dispatchEvent(new Event('input'));
                                }
                                if (document.getElementById('BAIRRO')) {
                                    document.getElementById('BAIRRO').value = data.bairro;
                                    document.getElementById('BAIRRO').dispatchEvent(new Event('input'));
                                }
                                if (document.getElementById('CIDADE')) {
                                    document.getElementById('CIDADE').value = data.localidade;
                                    document.getElementById('CIDADE').dispatchEvent(new Event('input'));
                                }
                                if (document.getElementById('UF')) {
                                    document.getElementById('UF').value = data.uf;
                                    document.getElementById('UF').dispatchEvent(new Event('change'));
                                }
                            } else {
                                if (typeof Swal !== 'undefined') {
                                    Swal.fire({
                                        title: 'Aviso',
                                        text: 'CEP não encontrado.',
                                        icon: 'warning',
                                        confirmButtonText: 'Ok'
                                    });
                                } else {
                                    alert('CEP não encontrado.');
                                }
                            }
                        })
                        .catch(err => console.error('Erro ao buscar CEP:', err))
                        .finally(() => {
                            fields.forEach(id => {
                                const el = document.getElementById(id);
                                if (el) el.placeholder = '';
                            });
                        });
                }
            });
        }

        const principalCheckbox = document.querySelector('input[name="PRINCIPAL"]');
        const tipoSelect = document.getElementById('TIPO_ID');
        if (principalCheckbox && tipoSelect) {
            function atualizarTipo() {
                if (principalCheckbox.checked) {
                    tipoSelect.value = 'COMERCIAL';
                    tipoSelect.disabled = true;
                } else {
                    tipoSelect.disabled = false;
                }
            }
            principalCheckbox.addEventListener('change', atualizarTipo);
            atualizarTipo();
        }
    });
</script>

{% endblock %}