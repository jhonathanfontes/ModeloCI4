{% extends 'Layouts/admin' %}
{% block page_title %}{{ empresa ? 'Editar Empresa' : 'Nova Empresa' }}{% endblock %}
{% block page_heading %}{{ empresa ? 'Editar Empresa' : 'Nova Empresa' }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas') }}">Empresas</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">{{ empresa ? 'Editar' : 'Novo' }}</span>
{% endblock %}
{% block page_actions %}
{% if empresa %}
<a href="{{ route_to('admin.empresas.usuarios', empresa.uuid) }}" class="btn btn-outline">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    Usuários
</a>
{% endif %}
{% endblock %}

{% block content %}

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

{% if errors is defined and errors|length > 0 %}
<div class="alert alert-error">
    <ul style="margin:0;padding-left:20px;">
    {% for field, msg in errors %}
        <li>{{ msg }}</li>
    {% endfor %}
    </ul>
</div>
{% endif %}

{% if empresa %}
<div class="tabs">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}" class="tab">Dados</a>
    <a href="{{ route_to('admin.empresas.enderecos', empresa.uuid) }}" class="tab">Endereços</a>
    <a href="{{ route_to('admin.empresas.contatos', empresa.uuid) }}" class="tab">Contatos</a>
    <a href="{{ route_to('admin.empresas.usuarios', empresa.uuid) }}" class="tab">Usuários</a>
    <a href="{{ route_to('admin.empresas.servicos', empresa.uuid) }}" class="tab">Serviços</a>
</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3>{{ empresa ? 'Editar Empresa' : 'Nova Empresa' }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ route_to('admin.empresas.salvar') }}">
            {{ csrf_field()|raw }}
            {% if empresa %}
            <input type="hidden" name="ID_EMPRESA" value="{{ empresa.id }}">
            {% endif %}

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="RAZAO_SOCIAL">Razão Social</label>
                    <input type="text" id="RAZAO_SOCIAL" name="RAZAO_SOCIAL" class="form-control" value="{{ old('RAZAO_SOCIAL', empresa.razaoSocial ?? '') }}" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="NOME_FANTASIA">Nome Fantasia</label>
                    <input type="text" id="NOME_FANTASIA" name="NOME_FANTASIA" class="form-control" value="{{ old('NOME_FANTASIA', empresa.nomeFantasia ?? '') }}" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="CPF_CNPJ">CPF/CNPJ</label>
                    <input type="text" id="CPF_CNPJ" name="CPF_CNPJ" class="form-control" value="{{ old('CPF_CNPJ', cnpjCpf(empresa.cpfCnpj ?? '')) }}" data-mask="cpfCnpj" placeholder="CPF ou CNPJ" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="EMAIL">E-mail</label>
                    <input type="email" id="EMAIL" name="EMAIL" class="form-control" value="{{ old('EMAIL', empresa.email ?? '') }}" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="TELEFONE">Telefone</label>
                    <input type="text" id="TELEFONE" name="TELEFONE" class="form-control" value="{{ old('TELEFONE', telefone(empresa.telefone ?? '')) }}" data-mask="telefone" placeholder="(99) 9999-9999">
                </div>

                <div class="form-group">
                    <label class="form-label" for="CELULAR">Celular</label>
                    <input type="text" id="CELULAR" name="CELULAR" class="form-control" value="{{ old('CELULAR', celular(empresa.celular ?? '')) }}" data-mask="celular" placeholder="(99) 99999-9999">
                </div>

                {% import 'Componentes/selectSituacao' as situacao %}
                {{ situacao.select('SITUACAO_ID', old('SITUACAO_ID', empresa.situacaoId ?? ''), 'SITUACAO_REGISTRO', 'ATIVO,INATIVO,PENDENTE,BLOQUEADO', { label: 'Situação', required: true }) }}
            </div>

            <div class="form-actions">
                <a href="{{ route_to('admin.empresas') }}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    {{ empresa ? 'Atualizar' : 'Salvar' }}
                </button>
            </div>
        </form>
    </div>
</div>

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const cnpjInput = document.getElementById('CPF_CNPJ');
        if (cnpjInput) {
            cnpjInput.addEventListener('blur', function() {
                const cnpj = this.value.replace(/\D/g, '');
                if (cnpj.length === 14) {
                    const fields = ['RAZAO_SOCIAL', 'NOME_FANTASIA', 'EMAIL', 'TELEFONE'];
                    fields.forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.placeholder = 'Carregando...';
                    });

                    fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`)
                        .then(response => {
                            if (!response.ok) throw new Error('CNPJ não encontrado ou erro na API');
                            return response.json();
                        })
                        .then(data => {
                            if (data.razao_social && document.getElementById('RAZAO_SOCIAL')) {
                                document.getElementById('RAZAO_SOCIAL').value = data.razao_social;
                                document.getElementById('RAZAO_SOCIAL').dispatchEvent(new Event('input'));
                            }
                            if (document.getElementById('NOME_FANTASIA')) {
                                document.getElementById('NOME_FANTASIA').value = data.nome_fantasia || data.razao_social || '';
                                document.getElementById('NOME_FANTASIA').dispatchEvent(new Event('input'));
                            }
                            if (data.email && document.getElementById('EMAIL')) {
                                document.getElementById('EMAIL').value = data.email;
                                document.getElementById('EMAIL').dispatchEvent(new Event('input'));
                            }
                            if (data.ddd_telefone_1 && document.getElementById('TELEFONE')) {
                                document.getElementById('TELEFONE').value = data.ddd_telefone_1;
                                document.getElementById('TELEFONE').dispatchEvent(new Event('input'));
                            }
                        })
                        .catch(err => {
                            console.error('Erro ao buscar CNPJ:', err);
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    title: 'Aviso',
                                    text: 'Não foi possível encontrar dados para este CNPJ automaticamente.',
                                    icon: 'info',
                                    confirmButtonText: 'Ok'
                                });
                            } else {
                                alert('Não foi possível encontrar dados para este CNPJ automaticamente.');
                            }
                        })
                        .finally(() => {
                            fields.forEach(id => {
                                const el = document.getElementById(id);
                                if (el) el.placeholder = '';
                            });
                        });
                }
            });
        }
    });
</script>
{% endblock %}
{% endblock %}
