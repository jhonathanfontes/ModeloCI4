{% extends 'Layouts/admin' %}
{% block page_title %}Usuários - {{ empresa.nomeFantasia }}{% endblock %}
{% block page_heading %}Usuários - {{ empresa.nomeFantasia }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas') }}">Empresas</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas.visualizar', empresa.id) }}">{{ empresa.nomeFantasia }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Usuários</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('admin.empresas.usuarios.vincular', empresa.id) }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/>
        <line x1="23" y1="11" x2="17" y2="11"/>
    </svg>
    Vincular Usuário
</a>
{% endblock %}

{% block content %}

{% if success %}
<div class="alert alert-success">{{ success }}</div>
{% endif %}

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

<div class="tabs">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.id) }}" class="tab">Dados</a>
    <a href="{{ route_to('admin.empresas.usuarios', empresa.id) }}" class="tab tab-active">Usuários</a>
    <a href="{{ route_to('admin.empresas.servicos', empresa.uuid) }}" class="tab">Serviços</a>
</div>

<div class="card">
    <div class="card-header">
        <h3>Usuários Vinculados</h3>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Perfil</th>
                        <th style="width:100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if usuarios is empty %}
                    <tr>
                        <td colspan="4" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">
                            Nenhum usuário vinculado a esta empresa.
                        </td>
                    </tr>
                    {% else %}
                    {% for u in usuarios %}
                    <tr>
                        <td>{{ u.USUARIO_NOME }}</td>
                        <td>{{ u.USUARIO_EMAIL }}</td>
                        <td>{{ u.PERFIL_NOME ?? '-' }}</td>
                        <td>
                            <form method="post" action="{{ route_to('admin.empresas.usuarios.desvincular', empresa.id, u.ID_USUARIO_EMPRESA) }}" class="inline-form" onsubmit="return confirm('Tem certeza que deseja desvincular este usuário?')">
                                <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Desvincular">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="form-actions">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.id) }}" class="btn btn-outline">Voltar para Empresa</a>
</div>

{% endblock %}
