{% extends 'Layouts/admin' %}
{% block page_title %}Contatos - {{ empresa.nomeFantasia }}{% endblock %}
{% block page_heading %}Contatos - {{ empresa.nomeFantasia }}{% endblock %}
{% block breadcrumb_items %}
<a href="{{ route_to('admin.dashboard') }}">Admin</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas') }}">Empresas</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}">{{ empresa.nomeFantasia }}</a>
<span style="color:var(--color-text-muted);margin:0 4px;">/</span>
<span style="color:var(--color-text-muted)">Contatos</span>
{% endblock %}
{% block page_actions %}
<a href="{{ route_to('admin.empresas.contatos.novo', empresa.uuid) }}" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Novo Contato
</a>
{% endblock %}

{% block content %}

{% if success %}
<div class="alert alert-success">{{ success }}</div>
{% endif %}

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

<div class="tabs">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}" class="tab">Dados</a>
    <a href="{{ route_to('admin.empresas.enderecos', empresa.uuid) }}" class="tab">Endereços</a>
    <a href="{{ route_to('admin.empresas.contatos', empresa.uuid) }}" class="tab tab-active">Contatos</a>
    <a href="{{ route_to('admin.empresas.usuarios', empresa.uuid) }}" class="tab">Usuários</a>
    <a href="{{ route_to('admin.empresas.servicos', empresa.uuid) }}" class="tab">Serviços</a>
</div>

<div class="card">
    <div class="card-header">
        <h3>Contatos</h3>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Cargo</th>
                        <th>Telefone</th>
                        <th>E-mail</th>
                        <th>WhatsApp</th>
                        <th>Principal</th>
                        <th style="width:120px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% if contatos is empty %}
                    <tr>
                        <td colspan="7" style="text-align:center;padding:32px 16px;color:var(--color-text-muted);">
                            Nenhum contato cadastrado para esta empresa.
                        </td>
                    </tr>
                    {% else %}
                    {% for c in contatos %}
                    <tr>
                        <td><div class="user-name">{{ c.NOME }}</div></td>
                        <td>{{ c.CARGO ?? '—' }}</td>
                        <td>{{ c.TELEFONE ? telefone(c.TELEFONE) : '—' }}</td>
                        <td>{{ c.EMAIL ?? '—' }}</td>
                        <td>{{ c.WHATSAPP ? celular(c.WHATSAPP) : '—' }}</td>
                        <td>{% if c.PRINCIPAL %}<span class="status status-active"><span class="status-dot"></span>Sim</span>{% else %}—{% endif %}</td>
                        <td>
                            <div class="action-group">
                                <a href="{{ route_to('admin.empresas.contatos.editar', empresa.uuid, c.ID_CONTATO) }}" class="btn btn-sm btn-outline" title="Editar">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ route_to('admin.empresas.contatos.excluir', empresa.uuid, c.ID_CONTATO) }}" class="inline-form" data-confirm="Tem certeza que deseja excluir este contato?">
                                    {{ csrf_field()|raw }}
                                    <button type="submit" class="btn btn-sm btn-outline btn-danger" title="Excluir">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                            <line x1="10" y1="11" x2="10" y2="17"/>
                                            <line x1="14" y1="11" x2="14" y2="17"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="form-actions">
    <a href="{{ route_to('admin.empresas.visualizar', empresa.uuid) }}" class="btn btn-outline">Voltar para Empresa</a>
</div>

{% endblock %}
